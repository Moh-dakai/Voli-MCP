# Data providers
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Economic calendar
FOREX_FACTORY_RSS_URL=https://www.forexfactory.com/ff_cal_thisweek.xml
CALENDAR_DISABLE_LIVE=false
# Optional JSON array to override events (useful for tests)
CALENDAR_OVERRIDE_EVENTS=
# Testing override (ISO-8601, e.g. 2026-03-06T12:00:00Z)
CALENDAR_NOW_UTC=

# Historical data storage
HISTORY_DB_PATH=src/data/session_history.db

# Range cache
RANGE_CACHE_PATH=src/data/range_cache.json
